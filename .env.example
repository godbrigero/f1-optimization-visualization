# MongoDB
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/f1-optimization"
MONGODB_DB="f1-optimization"

# LiveKit
LIVEKIT_URL="wss://your-project.livekit.cloud"
NEXT_PUBLIC_LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"

# DigitalOcean GenAI Platform / Serverless Inference
# Create a Model Access Key in DigitalOcean, then use an OpenAI-compatible model ID.
DIGITALOCEAN_MODEL_ACCESS_KEY="your-digitalocean-model-access-key"
DIGITALOCEAN_INFERENCE_BASE_URL="https://inference.do-ai.run/v1/"
DIGITALOCEAN_MODEL="llama3.3-70b-instruct"

# Default LLM provider used by /api/llm/chat.
LLM_PROVIDER="digitalocean"
