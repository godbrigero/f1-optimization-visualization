# LiveKit
LIVEKIT_URL="wss://your-project.livekit.cloud"
NEXT_PUBLIC_LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"
LIVEKIT_AGENT_ID="f1-voice-agent"
LIVEKIT_AGENT_STT_MODEL="deepgram/flux-general-en"
LIVEKIT_AGENT_TTS_MODEL="cartesia/sonic-3.5"
LIVEKIT_AGENT_TTS_VOICE="e2d48e7b-cc6d-4f97-a8fd-13c1449aeebd"
LIVEKIT_AGENT_TTS_SPEED="normal"
LIVEKIT_AGENT_TTS_MAX_BUFFER_DELAY_MS="120"
LIVEKIT_AGENT_MAX_COMPLETION_TOKENS="80"

# DigitalOcean GenAI / OpenAI-compatible model endpoint
DIGITALOCEAN_MODEL_API_KEY="your-digitalocean-model-api-key"
DIGITALOCEAN_MODEL_BASE_URL="https://inference.do-ai.run/v1"
DIGITALOCEAN_CHAT_MODEL="qwen3-coder-flash"
DIGITALOCEAN_SUMMARY_MODEL="alibaba-qwen3-32b"
DIGITALOCEAN_TTS_MODEL="qwen3-tts-voicedesign"
DIGITALOCEAN_TTS_VOICE="alloy"
DIGITALOCEAN_TTS_INSTRUCTIONS="Warm, natural, concise."
