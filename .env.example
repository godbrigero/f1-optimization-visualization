# LiveKit
LIVEKIT_URL="wss://your-project.livekit.cloud"
NEXT_PUBLIC_LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"

# DigitalOcean GenAI / OpenAI-compatible model endpoint
DIGITALOCEAN_MODEL_API_KEY="your-digitalocean-model-api-key"
DIGITALOCEAN_MODEL_BASE_URL="https://inference.do-ai.run/v1"
DIGITALOCEAN_CHAT_MODEL="openai-gpt-5.4-nano"
DIGITALOCEAN_SUMMARY_MODEL="alibaba-qwen3-32b"
DIGITALOCEAN_TTS_MODEL="qwen3-tts-voicedesign"
DIGITALOCEAN_TTS_VOICE="alloy"
DIGITALOCEAN_TTS_INSTRUCTIONS="A polished, warm, natural voice with calm confidence, clear pacing, and subtle energy. Avoid sounding robotic or overly dramatic."
